generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "darwin-arm64"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  password   String
  todos      Todo[]
  quicknotes Quicknote[]
  createdAt  DateTime    @default(now())
  habits     Habit[]
  habitLogs  habitLog[]
}

model Todo {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  note       Quicknote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId     Int?
  title      String
  completed  Boolean   @default(false)
  dueDate    DateTime?
  isPriority Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

model Quicknote {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  title     String
  content   String
  category  String
  todos     Todo[]
  createdAt DateTime @default(now())
}

model Habit {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  name      String
  type      String
  logs      habitLog[]
  createdAt DateTime   @default(now())
}

model habitLog {
  id        Int      @id @default(autoincrement())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  habitId   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  date      String
  value     String
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}
